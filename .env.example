# ============================================
# SALIN FILE INI MENJADI .env.local (lokal)
# atau isi di Environment Variables Vercel
# ============================================

# PostgreSQL - dapatkan dari neon.tech (gratis)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth - generate random string panjang
# bisa pakai: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-random-string-panjang"
NEXTAUTH_URL="https://nama-project-kamu.vercel.app"

# Kredensial login
KASIR_USERNAME="kasir"
KASIR_PASSWORD="ganti-password-kasir"

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ganti-password-admin"
